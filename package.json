{
  "name": "gms-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@gms/web",
    "build:web": "npm run build --workspace=@gms/web",
    "dev:api": "npm run dev --workspace=@gms/api",
    "build:api": "npm run build --workspace=@gms/api"
  }
}
