# Supabase project URL (found in Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe for client use, but we keep it server-side too)
SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — has full DB access, NEVER expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string — used by Drizzle for migrations
# Found in Project Settings → Database → Connection string → URI (use "Transaction" mode for pooled, "Session" for direct)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

PORT=3000
